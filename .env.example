# --- IBM Bob Shell (CLI subprocess) ---
# Obtain BOBSHELL_API_KEY from bob.ibm.com → Admin → API Keys
# BOB_MODEL: supported aliases: premium, premium-ide, gemini-3.5-flash, explorer, etc.
BOBSHELL_API_KEY=your_bob_shell_api_key_here
BOB_MODEL=premium

# --- Groq (fallback) ---
# Obtain GROQ_API_KEY from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Google Gemini (fallback) ---
# Obtain GEMINI_API_KEY from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# --- Provider Orchestration / Fallback ---
PRIMARY_PROVIDER=bob
# Comma-separated list for fallback order
FALLBACK_ORDER=bob,groq,gemini
