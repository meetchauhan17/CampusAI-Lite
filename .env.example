# --- IBM watsonx.ai (referred internally as "bob") ---
# Obtain BOBSHELL_API_KEY (IBM Cloud API Key) and BOB_PROJECT_ID from your IBM watsonx.ai platform project settings.
# BOB_URL is the Regional Endpoint URL (e.g., https://us-south.ml.cloud.ibm.com)
BOBSHELL_API_KEY=your_watsonx_api_key_here
BOB_PROJECT_ID=your_watsonx_project_id_here
BOB_URL=https://us-south.ml.cloud.ibm.com
BOB_MODEL=ibm/granite-3-8b-instruct

# --- Groq ---
# Obtain GROQ_API_KEY from the Groq console (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# --- Google Gemini ---
# Obtain GEMINI_API_KEY from Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Provider Orchestration / Fallback ---
PRIMARY_PROVIDER=bob
# Comma-separated list for fallback order
FALLBACK_ORDER=bob,groq,gemini
